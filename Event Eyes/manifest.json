{
  "manifest_version": 3,
  "name": "Event Eyes",
  "version": "1.2.0",
  "description": "Monitor GTM dataLayer and GA4 network events in real time.",
  "permissions": ["scripting", "activeTab"],
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["early.js"],
    "run_at": "document_start",
    "world": "MAIN"
  }],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Toggle Event Eyes"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
